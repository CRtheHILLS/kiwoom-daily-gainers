# Copy to ".env" and fill in only what you need. All are OPTIONAL.
# The core feature (today's gainers + supply/demand via Kiwoom) needs NO keys.

# Naver Search API — free, adds news headlines per stock (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Notion — optional export of the report to a Notion database
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Kiwoom REST (only if you wire up the REST API; the desktop OpenAPI+ OCX needs none)
APP_KEY=
APP_SECRET=
CUST_ID=
